# App config (required by src/lib/config.ts)
DATABASE_URL=postgresql://familyhub:familyhub@127.0.0.1:5432/familyhub?schema=public
JWT_SECRET=dev-family-secret
PORT=3000

# Demo auth identity (used by seed + health response)
DEMO_USER_EMAIL=parent@example.com
DEMO_USER_PASSWORD=family123

# Postgres bootstrap defaults (used by scripts/init-postgres.sh)
POSTGRES_USER=familyhub
POSTGRES_PASSWORD=familyhub
POSTGRES_DB=familyhub
POSTGRES_VERSION=15
POSTGRES_CLUSTER=main
