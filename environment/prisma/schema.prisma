generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  CAREGIVER
  CHILD
}

enum TaskCadence {
  ONE_TIME
  DAILY
  WEEKLY
  CUSTOM
}

enum TaskStatus {
  OPEN
  DONE
  SKIPPED
}

enum Visibility {
  PRIVATE
  SHARED
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  displayName      String
  createdAt        DateTime          @default(now())
  memberships      FamilyMember[]
  createdTasks     HouseholdTask[]   @relation("TaskCreator")
  assignedTasks    HouseholdTask[]   @relation("TaskAssignee")
  posts            FamilyPost[]
  comments         PostComment[]
  likes            PostLike[]
  reminders        Reminder[]
  locationCheckIns LocationCheckIn[]
}

model Family {
  id                     String            @id @default(cuid())
  slug                   String            @unique
  name                   String
  timezone               String
  locationSharingEnabled Boolean           @default(false)
  createdAt              DateTime          @default(now())
  memberships            FamilyMember[]
  tasks                  HouseholdTask[]
  events                 CalendarEvent[]
  reminders              Reminder[]
  lists                  FamilyList[]
  posts                  FamilyPost[]
  locationCheckIns       LocationCheckIn[]
}

model FamilyMember {
  id          String     @id @default(cuid())
  familyId    String
  userId      String
  role        MemberRole
  permissions Json
  createdAt   DateTime   @default(now())
  family      Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
}

model HouseholdTask {
  id          String       @id @default(cuid())
  familyId    String
  createdById String
  assigneeId  String?
  title       String
  description String?
  cadence     TaskCadence
  status      TaskStatus   @default(OPEN)
  visibility  Visibility   @default(SHARED)
  dueAt       DateTime?
  createdAt   DateTime     @default(now())
  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([familyId, status])
}

model CalendarEvent {
  id          String     @id @default(cuid())
  familyId    String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  visibility  Visibility @default(SHARED)
  createdAt   DateTime   @default(now())
  family      Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, startsAt])
}

model Reminder {
  id           String     @id @default(cuid())
  familyId     String
  recipientId  String?
  title        String
  scheduleText String
  createdAt    DateTime   @default(now())
  family       Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  recipient    User?      @relation(fields: [recipientId], references: [id], onDelete: SetNull)
}

model FamilyList {
  id         String           @id @default(cuid())
  familyId   String
  title      String
  visibility Visibility       @default(SHARED)
  createdAt  DateTime         @default(now())
  family     Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  items      FamilyListItem[]
}

model FamilyListItem {
  id         String     @id @default(cuid())
  listId     String
  label      String
  completed  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  familyList FamilyList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model FamilyPost {
  id          String        @id @default(cuid())
  familyId    String
  authorId    String
  body        String
  mediaUrl    String?
  createdAt   DateTime      @default(now())
  family      Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    PostComment[]
  likes       PostLike[]

  @@index([familyId, createdAt])
}

model PostComment {
  id        String     @id @default(cuid())
  postId     String
  authorId   String
  body       String
  createdAt  DateTime   @default(now())
  post       FamilyPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model PostLike {
  id        String     @id @default(cuid())
  postId     String
  userId     String
  createdAt  DateTime   @default(now())
  post       FamilyPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model LocationCheckIn {
  id         String    @id @default(cuid())
  familyId   String
  userId     String
  label      String
  latitude   Float
  longitude  Float
  createdAt  DateTime  @default(now())
  family     Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt])
}
